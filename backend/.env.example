# ── LLM Providers ─────────────────────────────────────────────────
# At least one LLM provider is required for narrative generation.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Which LLM provider to use: "anthropic" or "openai" (default: anthropic)
# RED_IRON_SQUARE_LLM_PROVIDER=anthropic

# ── ElevenLabs (Text-to-Speech) ───────────────────────────────────
# Required for voice synthesis in the Two Minds demo.
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── Logging ───────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# ── Flask UI ──────────────────────────────────────────────────────
# FLASK_SECRET_KEY=red-iron-square-dev
# FLASK_DEBUG=0
# RED_IRON_SQUARE_API_URL=http://127.0.0.1:8000
